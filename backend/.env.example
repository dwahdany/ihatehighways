GOOGLE_MAPS_API_KEY=
IHH_MOCK=0
IHH_CORS_ORIGINS=http://localhost:5173

# Wallet guard (counts uncached plans only)
RATE_PER_IP_HOUR=10
RATE_DAILY_CAP=100
# Enable only behind a trusted reverse proxy (uses X-Forwarded-For)
TRUST_FORWARDED_FOR=0

# OSM corridor pre-filter (free Overpass data gates paid Google detour probes)
OSM_ENABLED=1
OSM_MIN_CURVY_KM=2.0
